@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix scinex: <https://w3id.org/scinex#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcterms:created a owl:AnnotationProperty .

dcterms:title a owl:AnnotationProperty .

<http://www.semanticweb.org/dochimac/ontologies/2026/4/core-experiment-ontology> a owl:Ontology ;
    dcterms:created "2026-05-22"^^xsd:date ;
    dcterms:title "Core Experiment Ontology (scinex)" ;
    rdfs:comment "A core ontology (T-Box) for representing scientific experimental components, enabling experiment-level knowledge alignment across academic publications. Initial scope targets the Computer Science domain." ;
    owl:versionInfo "0.7.0" .

scinex:Affiliation a owl:Class ;
    rdfs:label "Affiliation" ;
    rdfs:comment "A research-oriented organisation to which an author is professionally associated at the time of a publication, such as a university department, research institute, or industrial laboratory. Representing affiliations enables institutional attribution, collaboration network analysis, and geographic distribution of research." ;
    rdfs:subClassOf scinex:Organisation .

scinex:BaselineModel a owl:Class ;
    rdfs:label "Baseline Model" ;
    rdfs:comment "A reference model representing a prior or standard approach, used as a comparison point to contextualise the performance of a proposed method. Without a well-defined baseline, experimental claims cannot be objectively evaluated." ;
    rdfs:subClassOf scinex:Model .

scinex:Biology a owl:Class ;
    rdfs:label "Biology" ;
    rdfs:comment "The natural science that studies life, living organisms, and their biological processes, structures, and evolution." ;
    rdfs:subClassOf scinex:NaturalScience .

scinex:Chemistry a owl:Class ;
    rdfs:label "Chemistry" ;
    rdfs:comment "The natural science that studies the composition, structure, properties, and transformation of matter at the molecular and atomic level." ;
    rdfs:subClassOf scinex:NaturalScience .

scinex:ComputerScience a owl:Class ;
    rdfs:label "Computer Science" ;
    rdfs:comment "The formal science concerned with algorithms, data structures, software systems, and computation theory. This is the primary domain targeted in the initial scope of this ontology." ;
    rdfs:subClassOf scinex:FormalScience .

scinex:Conference a owl:Class ;
    rdfs:label "Conference" ;
    rdfs:comment "An academic event at which researchers present and discuss their work, producing citable proceedings. Conference papers typically undergo peer review." ;
    rdfs:subClassOf scinex:PublicationVenue .

scinex:Country a owl:Class ;
    rdfs:label "Country" ;
    rdfs:comment "A sovereign geopolitical territory in which an organisation or affiliation is located. Representing countries as a named class rather than a literal string enables LOD alignment (e.g., via owl:sameAs links to DBpedia or Wikidata country URIs) and supports geographic analysis of research output." ;
    rdfs:subClassOf scinex:Place .

scinex:DataProcessing a owl:Class ;
    rdfs:label "Data Processing" ;
    rdfs:comment "A transformation or pipeline of transformations applied to raw or intermediate data to prepare it for use in an experiment. Typical steps include data cleaning, normalisation, tokenisation, feature engineering, and augmentation. Explicit representation of data processing steps is critical for experiment reproducibility." ;
    rdfs:subClassOf scinex:ResearchProcess .

scinex:Hyperparameter a owl:Class ;
    rdfs:label "Hyperparameter" ;
    rdfs:comment "A configuration parameter set prior to the training process that governs the learning behaviour of a model, such as learning rate, batch size, number of layers, dropout rate, or optimiser type. Hyperparameters are a critical subtype of experimental condition; their omission in a paper is one of the most common reproducibility barriers." ;
    rdfs:subClassOf scinex:ExperimentalCondition .

scinex:Journal a owl:Class ;
    rdfs:label "Journal" ;
    rdfs:comment "A periodical publication that disseminates peer-reviewed scholarly articles on a continuing basis within one or more research domains." ;
    rdfs:subClassOf scinex:PublicationVenue .

scinex:Mathematics a owl:Class ;
    rdfs:label "Mathematics" ;
    rdfs:comment "The formal science of number, quantity, structure, and space, providing the theoretical foundation for most quantitative scientific disciplines." ;
    rdfs:subClassOf scinex:FormalScience .

scinex:Methodology a owl:Class ;
    rdfs:label "Methodology" ;
    rdfs:comment "The overall research strategy or approach adopted in a study to achieve its objectives. A methodology encompasses the selection of methods, experimental design, and evaluation strategy. It is a distinct entity from the paper that reports it — the same methodology can be reused or adapted across multiple studies." ;
    rdfs:subClassOf scinex:ResearchProcess .

scinex:Physics a owl:Class ;
    rdfs:label "Physics" ;
    rdfs:comment "The natural science that studies matter, energy, and the fundamental forces governing the physical universe." ;
    rdfs:subClassOf scinex:NaturalScience .

scinex:ProposedModel a owl:Class ;
    rdfs:label "Proposed Model" ;
    rdfs:comment "A novel model, architecture, or method introduced by the paper's authors as the primary contribution, evaluated against one or more baseline models." ;
    rdfs:subClassOf scinex:Model .

scinex:Statistics a owl:Class ;
    rdfs:label "Statistics" ;
    rdfs:comment "The discipline concerned with the collection, analysis, interpretation, and presentation of numerical data, widely applied in the design and evaluation of scientific experiments." ;
    rdfs:subClassOf scinex:FormalScience .

scinex:TestDataset a owl:Class ;
    rdfs:label "Test Dataset" ;
    rdfs:comment "A held-out portion of a dataset used exclusively to assess the final, unbiased performance of a trained model. It must not be seen during training or validation." ;
    rdfs:subClassOf scinex:Dataset .

scinex:ValidationDataset a owl:Class ;
    rdfs:label "Validation Dataset" ;
    rdfs:comment "A held-out portion of a dataset used to tune hyperparameters and monitor for overfitting during training, kept separate from the test set to avoid information leakage." ;
    rdfs:subClassOf scinex:Dataset .

scinex:Workshop a owl:Class ;
    rdfs:label "Workshop" ;
    rdfs:comment "A focused academic event, typically co-located with a conference, targeting an emerging or specialised research area. Workshop papers often present preliminary or exploratory work." ;
    rdfs:subClassOf scinex:PublicationVenue .

scinex:achieves a owl:ObjectProperty ;
    rdfs:label "achieves" ;
    rdfs:comment "Links a research process to the research objective it fulfils. This is the inverse of scinex:motivates: the reasoner automatically infers that if objective O motivates process P, then process P achieves objective O. Enables queries from the process side ('what objective does this experiment achieve?') without requiring explicit triple authoring, supporting bidirectional objective–process reasoning across papers." ;
    rdfs:domain scinex:ResearchProcess ;
    rdfs:range scinex:ResearchObjective ;
    owl:inverseOf scinex:motivates .

scinex:achievesResult a owl:ObjectProperty ;
    rdfs:label "achieves result" ;
    rdfs:comment "Links a model to an experimental result (metric outcome) it achieves." ;
    rdfs:domain scinex:Model ;
    rdfs:range scinex:ExperimentalResult .

scinex:addresses a owl:ObjectProperty ;
    rdfs:label "addresses" ;
    rdfs:comment "Links a publication or a research process to the research context element it targets. An academic paper addresses its research domain, objectives, or thematic scope; an experiment addresses the research task it is designed to solve. A single generalised property over both Publications and ResearchProcesses avoids proliferating narrow predicates for each context subtype." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( scinex:Publication scinex:ResearchProcess ) ] ;
    rdfs:range scinex:ResearchContext .

scinex:affiliatedWith a owl:ObjectProperty ;
    rdfs:label "affiliatedWith" ;
    rdfs:comment "Associates an agent with an organisation to which they are professionally attached during a research activity. The domain is Agent (not only Person) because organisations can also be affiliated with other organisations, e.g. consortium memberships. In the most common use case this links an Author (a subclass of Person, which is a subclass of Agent) to the institution listed alongside their name in a paper. Because Affiliation is a subclass of Organisation, the property applies to affiliations without a separate predicate." ;
    rdfs:domain scinex:Agent ;
    rdfs:range scinex:Organisation .

scinex:cites a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "cites" ;
    rdfs:comment "Records a bibliographic reference from one academic paper to another, indicating that the citing paper acknowledges, builds upon, or contrasts with the cited work. Declared irreflexive to prevent a paper from citing itself. Not declared asymmetric because mutual citation between two papers is an observable and valid scenario. Supports citation network analysis and provenance tracking across the knowledge graph." ;
    rdfs:domain scinex:AcademicPaper ;
    rdfs:range scinex:AcademicPaper .

scinex:comparesAgainst a owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "comparesAgainst" ;
    rdfs:comment "Associates a model with another model to which it is directly compared in an experiment. The primary use case is to link a ProposedModel to the BaselineModel(s) against which its performance is benchmarked. Declared irreflexive to prevent a model from being compared to itself. Not declared asymmetric because reciprocal comparison entries can appear in different papers. Enables structured retrieval of comparison pairs for cross-paper performance analysis." ;
    rdfs:domain scinex:Model ;
    rdfs:range scinex:Model .

scinex:configures a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "configures" ;
    rdfs:comment "Associates an experimental specification with the experiment it governs, establishing the conditions under which the experiment runs or the criteria by which its results are assessed. Declared asymmetric and irreflexive to enforce directionality: a specification configures an experiment, never vice versa. Because ExperimentalCondition and EvaluationMetric are both subclasses of ExperimentalSpecification, both condition-level and metric-level specifications are captured by this single property." ;
    rdfs:domain scinex:ExperimentalSpecification ;
    rdfs:range scinex:Experiment .

scinex:designedFor a owl:ObjectProperty ;
    rdfs:label "designedFor" ;
    rdfs:comment "Associates a model with the research task it was specifically designed or optimised to solve, such as a transformer model designed for machine translation or a CNN designed for image classification. This property gives Model (and its subclasses BaselineModel and ProposedModel) a direct domain role, enabling triple extraction statements such as 'Model X is designed for Task Y' from the Methods section of a paper." ;
    rdfs:domain scinex:Model ;
    rdfs:range scinex:ResearchTask .

scinex:employs a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "employs" ;
    rdfs:comment "Associates an organisation with the persons who work for or are institutionally employed by it at the time of a research publication. Provides the institution-perspective complement to scinex:affiliatedWith (the agent-perspective link), completing the bidirectional author–institution relationship. Declared asymmetric and irreflexive since an organisation does not employ itself. Enables institutional queries such as 'how many authors employed by Organisation X have published at Venue Y?'" ;
    rdfs:domain scinex:Organisation ;
    rdfs:range scinex:Person .

scinex:encompasses a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "encompasses" ;
    rdfs:comment "Relates a research domain to the research tasks that fall within its scope. For example, Computer Science encompasses text classification; Biology encompasses protein structure prediction. Declared asymmetric to enforce that a task does not encompass its parent domain, and irreflexive to prevent a domain from encompassing itself. This property gives all ResearchDomain subclasses (NaturalScience, FormalScience, and their leaves) a direct domain role, enabling extraction of domain–task scope statements that recur in introductory and related-work sections of papers." ;
    rdfs:domain scinex:ResearchDomain ;
    rdfs:range scinex:ResearchTask .

scinex:evaluatedOn a owl:ObjectProperty ;
    rdfs:label "evaluatedOn" ;
    rdfs:comment "Directly links an experiment to the dataset used to assess the final performance of its model(s). More specific than scinex:uses, this property captures evaluation semantics: the dataset serves as the benchmark surface, not merely a consumed input. Applies most naturally when the range is a TestDataset or ValidationDataset instance. Enables cross-paper queries such as 'which experiments report results on benchmark Dataset D?' without sifting through all uses triples." ;
    rdfs:domain scinex:Experiment ;
    rdfs:range scinex:Dataset .

scinex:evaluates a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "evaluates" ;
    rdfs:comment "Links an evaluation metric to the experimental result it quantitatively assesses. An evaluation metric evaluates a result by applying a defined mathematical criterion (e.g., F1 Score evaluates a classification result). Declared asymmetric to enforce that a result does not evaluate its metric. This property is central to cross-paper performance comparison and reproducibility analysis." ;
    rdfs:domain scinex:EvaluationMetric ;
    rdfs:range scinex:ExperimentalResult .

scinex:hasMetricName a owl:DatatypeProperty ;
    rdfs:label "metric name" ;
    rdfs:comment "The name of the evaluation metric reported (e.g. accuracy, F1, BLEU)." ;
    rdfs:domain scinex:ExperimentalResult ;
    rdfs:range xsd:string .

scinex:hasMetricValue a owl:DatatypeProperty ;
    rdfs:label "metric value" ;
    rdfs:comment "The numeric value of the reported evaluation metric." ;
    rdfs:domain scinex:ExperimentalResult ;
    rdfs:range xsd:double .

scinex:hasPaperId a owl:DatatypeProperty ;
    rdfs:label "paper id" ;
    rdfs:comment "The source-corpus identifier of the paper (e.g. ACL Anthology ID)." ;
    rdfs:domain scinex:AcademicPaper ;
    rdfs:range xsd:string .

scinex:hasSourceSentence a owl:DatatypeProperty ;
    rdfs:label "source sentence" ;
    rdfs:comment "The sentence in the source paper from which an entity or assertion was extracted." ;
    rdfs:range xsd:string .

scinex:hasTitle a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:comment "The full title of the academic paper." ;
    rdfs:domain scinex:AcademicPaper ;
    rdfs:range xsd:string .

scinex:locatedIn a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "locatedIn" ;
    rdfs:comment "Associates an organisation with the geographic place in which it is situated. Declared transitive to propagate geographic containment up the place hierarchy (campus → city → country), so a single assertion at the finest granularity is automatically inferred at coarser levels. Declared asymmetric and irreflexive to enforce that a place is not located in its own sub-locations. Representing this as an object property over typed Place instances enables LOD alignment with DBpedia, Wikidata, and GeoNames." ;
    rdfs:domain scinex:Organisation ;
    rdfs:range scinex:Place .

scinex:producedBy a owl:ObjectProperty ;
    rdfs:label "producedBy" ;
    rdfs:comment "Links a research artifact back to the research process that generated it. This is the inverse of scinex:produces: the reasoner automatically derives producedBy triples from every scinex:produces assertion. Enables backward traversal from an artifact to its originating process and, transitively via the comprises chain, to the enclosing methodology and its reporting paper. Supports queries such as 'which experiment produced this result?'" ;
    rdfs:domain scinex:ResearchArtifact ;
    rdfs:range scinex:ResearchProcess ;
    owl:inverseOf scinex:produces .

scinex:publishedIn a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "publishedIn" ;
    rdfs:comment "Links an academic paper to the publication venue in which it appears, such as a journal, conference, or workshop. Declared asymmetric and irreflexive to enforce directionality. Because Journal, Conference, and Workshop are all subclasses of PublicationVenue, the range constraint covers all venue types without specialisation." ;
    rdfs:domain scinex:AcademicPaper ;
    rdfs:range scinex:PublicationVenue .

scinex:splitFrom a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "splitFrom" ;
    rdfs:comment "Records that a dataset partition was derived from a larger source dataset. Declared asymmetric and irreflexive to prevent circular provenance chains (a source dataset is not split from its own splits, and a dataset is not split from itself). This self-referential property over Dataset gives TrainingDataset, ValidationDataset, and TestDataset a direct domain role, enabling extraction of data-split provenance statements that frequently appear in experimental setup sections of papers." ;
    rdfs:domain scinex:Dataset ;
    rdfs:range scinex:Dataset .

scinex:supports a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "supports" ;
    rdfs:comment "Links a quantitative experimental measurement to the qualitative conclusion it provides evidence for. A single numerical result (e.g., F1 = 0.91 on the test set) supports a broader outcome claim (e.g., the proposed model outperforms all baselines). Declared asymmetric to enforce that an outcome does not support its own measurements. Enables extraction of evidence–conclusion triples from results and discussion sections of papers." ;
    rdfs:domain scinex:ExperimentalMeasurement ;
    rdfs:range scinex:ExperimentalOutcome .

scinex:trainedOn a owl:ObjectProperty ;
    rdfs:label "trainedOn" ;
    rdfs:comment "Directly links a model to the training dataset used to optimise its parameters during the learning phase. More specific than scinex:uses, this property captures the training semantics of the model–data relationship. Applies to ProposedModel and BaselineModel instances alike, supporting cross-paper comparisons of training data choices and enabling queries such as 'which models were trained on Dataset D?'" ;
    rdfs:domain scinex:Model ;
    rdfs:range scinex:TrainingDataset .

scinex:writes a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "writes" ;
    rdfs:comment "Links an author to an academic paper to which they have contributed as a named author. Declared asymmetric and irreflexive to enforce directionality. The inverse property scinex:writtenBy enables paper-to-author backward traversal, supporting authorship attribution and researcher-level knowledge alignment queries from either direction." ;
    rdfs:domain scinex:Author ;
    rdfs:range scinex:AcademicPaper ;
    owl:inverseOf scinex:writtenBy .

