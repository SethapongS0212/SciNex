scinex:Agent a owl:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "An entity — a person or organisation — that bears a role in the production, dissemination, or consumption of scientific research. Subclasses cover individual contributors (Person → Author) and institutional bodies (Organisation → Affiliation)." .

scinex:ExperimentalSpecification a owl:Class ;
    rdfs:label "Experimental Specification" ;
    rdfs:comment "An information artifact that formally describes how an experiment is configured or how its results are to be measured. Specifications are not activities (they do not run experiments) nor outcomes (they do not record results) — they define the rules and settings under which experiments operate. Subclasses cover the configuration space (ExperimentalCondition) and the measurement criteria (EvaluationMetric)." ;
    rdfs:subClassOf scinex:ResearchArtifact .

scinex:FormalScience a owl:Class ;
    rdfs:label "Formal Science" ;
    rdfs:comment "A branch of science that investigates formal systems — such as logic, mathematics, and computation — through deductive reasoning rather than empirical observation." ;
    rdfs:subClassOf scinex:ResearchDomain .

scinex:NaturalScience a owl:Class ;
    rdfs:label "Natural Science" ;
    rdfs:comment "A branch of science that seeks to describe and explain natural phenomena through empirical observation and experimentation." ;
    rdfs:subClassOf scinex:ResearchDomain .

scinex:Publication a owl:Class ;
    rdfs:label "Publication" ;
    rdfs:comment "A scholarly communication entity within the academic publishing ecosystem. Subclasses cover both the document being published (AcademicPaper) and the forum through which it is disseminated (PublicationVenue)." .

scinex:ResearchDomain a owl:Class ;
    rdfs:label "Research Domain" ;
    rdfs:comment "The broad area of scientific inquiry in which a study is situated. Research domains facilitate cross-domain knowledge alignment and support the discovery of methodological patterns across disciplines." ;
    rdfs:subClassOf scinex:ResearchContext .

scinex:comprises a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "comprises" ;
    rdfs:comment "Relates a research process to a constituent sub-process that forms a structural part of it. Declared transitive: a high-level methodology is inferred to comprise all nested sub-processes at any depth of decomposition. Declared asymmetric and irreflexive to enforce a strict hierarchy (a sub-process cannot contain its ancestor, and a process cannot comprise itself). Property-chain axioms on scinex:uses and scinex:produces propagate resource usage and result attribution up the entire process tree." ;
    rdfs:domain scinex:ResearchProcess ;
    rdfs:range scinex:ResearchProcess .

<https://w3id.org/scinex/resource/2020.conll-1.24/cata> a owl:NamedIndividual,
        scinex:Model ;
    rdfs:label "cata" ;
    skos:definition "CATA is a model that stands for Categorical Argument." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/2020.conll-1.24> ;
    scinex:hasSourceSentence "We then mix in the object/subject vectors and obtain three different models: CA for Copy Argument, CAS for Copy Argument Sum and CATA for Categorical Argument; see Table 4." .

<https://w3id.org/scinex/resource/2020.conll-1.24/vskip> a owl:NamedIndividual,
        scinex:Model ;
    rdfs:label "vskip" ;
    skos:definition "Vskip is a baseline model representing the original skipgram vector of the verb." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/2020.conll-1.24> ;
    scinex:hasSourceSentence "As baselines, we additionally train unary maps Vsent|s (1) and Vsent|o (1), which predict a full sentence context given the subject or object of the verb, and vskip for the original skipgram vector of the verb." .

<https://w3id.org/scinex/resource/D12-1048/woeparse> a owl:NamedIndividual,
        scinex:Model ;
    rdfs:label "woeparse" ;
    skos:definition "WOEparse is a system that exhibits lower precision and yield compared to OLLIE in experimental evaluations." ;
    scinex:comparesAgainst <https://w3id.org/scinex/resource/D12-1048/ollie> ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/D12-1048> ;
    scinex:hasSourceSentence "In our experiments (see Figure 5) we find WOEparse to have lower precision and yield than OLLIE." .

<https://w3id.org/scinex/resource/P19-1048/gold_opinion_terms> a owl:NamedIndividual,
        scinex:Dataset ;
    rdfs:label "gold opinion terms" ;
    skos:definition "Gold opinion terms are data made available to AS models like ALSTM and dTrans during training for pipeline methods." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/P19-1048> ;
    scinex:hasSourceSentence "In addition, for pipeline methods, we also make the gold opinion terms available to the AS models (ALSTM and dTrans) during training." .

<https://w3id.org/scinex/resource/S16-1018/training_set> a owl:NamedIndividual,
        scinex:Dataset ;
    rdfs:label "training set" ;
    skos:definition "A training set is a dataset from which 10% of examples are extracted to form a validation set and which contains minority examples used to create bootstrap samples." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/S16-1018> ;
    scinex:hasSourceSentence "From the training set 10% of examples were ex- tracted to form a validation set." .

<https://w3id.org/scinex/resource/paper/D12-1048> a owl:NamedIndividual,
        scinex:AcademicPaper ;
    rdfs:label "Open Language Learning for Information Extraction" ;
    scinex:hasPaperId "D12-1048" ;
    scinex:hasTitle "Open Language Learning for Information Extraction" ;
    scinex:mentions <https://w3id.org/scinex/resource/D12-1048/ollie>,
        <https://w3id.org/scinex/resource/D12-1048/reverb>,
        <https://w3id.org/scinex/resource/D12-1048/woeparse> .

scinex:Organisation a owl:Class ;
    rdfs:label "Organisation" ;
    rdfs:comment "An institution or corporate body that plays a role in the research ecosystem, such as a university, research institute, funding body, or company. Organisations can employ researchers, produce papers, and host affiliations. Representing them as agents enables institutional-level knowledge alignment and collaboration network analysis." ;
    rdfs:subClassOf scinex:Agent .

scinex:PublicationVenue a owl:Class ;
    rdfs:label "Publication Venue" ;
    rdfs:comment "A forum or channel through which academic papers are disseminated to the scientific community. In library science, journals, conferences, and workshops are themselves considered serial or periodic publications, making them a subclass of Publication." ;
    rdfs:subClassOf scinex:Publication .

scinex:ResearchContext a owl:Class ;
    rdfs:label "Research Context" ;
    rdfs:comment "A conceptual element that frames or scopes a scientific study. Research context captures the disciplinary setting (domain), the intended goals (objective), and the concrete problem being solved (task). These elements are essential for aligning experiments across papers that address similar problems under different terminology." .

<https://w3id.org/scinex/resource/2020.conll-1.24/dependency_based_embeddings> a owl:NamedIndividual,
        scinex:Model ;
    rdfs:label "dependency based embeddings" ;
    skos:definition "Dependency based embeddings are a model proposed by Levy and Goldberg (2014) that serves as a reference for vector similarity." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/2020.conll-1.24> ;
    scinex:hasSourceSentence "These vectors are similar to the dependency based embeddings of Levy and Goldberg (2014)." .

<https://w3id.org/scinex/resource/D12-1051/phrase_chunking> a owl:NamedIndividual,
        scinex:ResearchTask ;
    rdfs:label "phrase chunking" ;
    skos:definition "Phrase chunking is a research task that can be modeled using a joint segmentation and labeling approach to offer advantages over previous learning methods." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/D12-1051> ;
    scinex:hasSourceSentence "Recently, CRFs were widely employed for phrase chunking, and presented comparable or better performance than other state-of-the-art models." .

<https://w3id.org/scinex/resource/S16-1018/lexical_and_semantic_features> a owl:NamedIndividual,
        scinex:TrainingDataset ;
    rdfs:label "lexical and semantic features" ;
    skos:definition "A training dataset comprising a wide range of lexical and semantic features, including n-grams, k-grams, Brown clustering, sentiment lexicons, SentiWordNet, and part-of-speech tagged 1-grams." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/S16-1018> ;
    scinex:hasSourceSentence "The proposed approach combines Ran- dom Forests, Support Vector Machines, and Gradi- ent Boosting Trees, trained on a wide range of lex- ical and semantic features including: n-grams, k- grams, Brown clustering, sentiment lexicons, Senti- WordNet, and part of speech tagged 1-grams." .

<https://w3id.org/scinex/resource/paper/E14-4003> a owl:NamedIndividual,
        scinex:AcademicPaper ;
    rdfs:label "Chinese Open Relation Extraction for Knowledge Acquisition" ;
    scinex:hasPaperId "E14-4003" ;
