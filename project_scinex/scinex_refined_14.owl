scinex:Dataset a owl:Class ;
    rdfs:label "Dataset" ;
    rdfs:comment "A structured collection of data instances used as input to an experiment, as a benchmark for performance evaluation, or as the material on which a model is trained, validated, or tested. A dataset is an independent, potentially reusable artifact that may be referenced across multiple papers." ;
    rdfs:subClassOf scinex:ResearchArtifact .

scinex:AcademicPaper a owl:Class ;
    rdfs:label "Academic Paper" ;
    rdfs:comment "A scholarly document that reports the findings of a scientific study, typically including research objectives, methodology, experimental design, and results. It is the primary unit of knowledge representation in this ontology." ;
    rdfs:subClassOf bibo:AcademicArticle,
        scinex:Publication .

scinex:Model a owl:Class ;
    rdfs:label "Model" ;
    rdfs:comment "A computational or mathematical construct that is trained, fine-tuned, or applied within an experiment to perform a specific research task. A model is an independent artifact that can be referenced across multiple experiments and papers, enabling cross-paper comparison." ;
    rdfs:subClassOf scinex:ResearchArtifact .

