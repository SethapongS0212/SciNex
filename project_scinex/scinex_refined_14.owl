scinex:TrainingDataset a owl:Class ;
    rdfs:label "Training Dataset" ;
    rdfs:comment "A portion of a dataset used to optimise the parameters of a model during the learning phase of an experiment." ;
    rdfs:subClassOf scinex:Dataset .

scinex:ResearchProcess a owl:Class ;
    rdfs:label "Research Process" ;
    rdfs:comment "A planned activity or sequence of activities carried out in a scientific study to produce, validate, or refine knowledge. Research processes range from high-level strategic planning (Methodology) to concrete data transformations (DataProcessing) and empirical investigations (Experiment)." .

scinex:ResearchArtifact a owl:Class ;
    rdfs:label "Research Artifact" ;
    rdfs:comment "An entity that is created, used, or consumed as part of a research process. Research artifacts include the data that experiments are trained and tested on (Dataset), the computational constructs being evaluated (Model), the specifications governing how experiments are run and measured (ExperimentalSpecification), and the outputs they produce (ExperimentalResult)." .

scinex:ResearchTask a owl:Class ;
    rdfs:label "Research Task" ;
    rdfs:comment "The specific computational or scientific problem that an experiment is designed to address, such as text classification, image segmentation, or machine translation. Identifying the task enables meaningful cross-paper comparison of methods and results that transcends surface-level terminology differences." ;
    rdfs:subClassOf scinex:ResearchContext .

