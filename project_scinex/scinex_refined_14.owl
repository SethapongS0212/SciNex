scinex:ExperimentalResult a owl:Class ;
    rdfs:label "Experimental Result" ;
    rdfs:comment "An artifact produced by an experiment, encompassing both quantitative measurements and qualitative observations obtained from executing an experimental procedure under defined conditions. Results are distinct from the experiments that produce them and are the primary evidence for cross-paper knowledge alignment." ;
    rdfs:subClassOf scinex:ResearchArtifact .

