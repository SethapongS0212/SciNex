bibo:AcademicArticle a owl:Class .

foaf:Person a owl:Class .

scinex:EvaluationMetric a owl:Class ;
    rdfs:label "Evaluation Metric" ;
    rdfs:comment "A quantitative criterion that specifies how the performance of a model or method is to be assessed within an experiment, such as Accuracy, F1 Score, BLEU, ROUGE, or Mean Squared Error. Evaluation metrics are independent, reusable specifications shared across papers and tasks; aligning their definitions is central to cross-paper experiment comparison." ;
    rdfs:subClassOf scinex:ExperimentalSpecification .

scinex:ExperimentalCondition a owl:Class ;
    rdfs:label "Experimental Condition" ;
    rdfs:comment "A specific configuration of variables, parameters, or environmental settings under which an experiment is executed. Representing distinct conditions enables controlled comparison of outcomes across different experimental setups, which is essential for reproducibility analysis." ;
    rdfs:subClassOf scinex:ExperimentalSpecification .

scinex:ExperimentalMeasurement a owl:Class ;
    rdfs:label "Experimental Measurement" ;
    rdfs:comment "A quantitative value recorded as the outcome of an experiment, associated with a specific evaluation metric and experimental condition (e.g., F1 = 0.87 on the test set with learning rate 0.001). Measurements are the primary evidence for comparing experimental claims across papers." ;
    rdfs:subClassOf scinex:ExperimentalResult .

scinex:ExperimentalOutcome a owl:Class ;
    rdfs:label "Experimental Outcome" ;
    rdfs:comment "A qualitative or interpretive conclusion derived from one or more experimental measurements, such as the finding that a proposed model outperforms all baselines on a given task, or that a specific preprocessing step is the dominant factor influencing performance." ;
    rdfs:subClassOf scinex:ExperimentalResult .

scinex:extractedFrom a owl:ObjectProperty ;
    rdfs:label "extracted from" ;
    rdfs:comment "Links an extracted entity to the academic paper it was extracted from." ;
    rdfs:range scinex:AcademicPaper ;
    owl:inverseOf scinex:mentions .

scinex:mentions a owl:ObjectProperty ;
    rdfs:label "mentions" ;
    rdfs:comment "Links an academic paper to an entity, model, dataset or result extracted from it." ;
    rdfs:domain scinex:AcademicPaper ;
    owl:inverseOf scinex:extractedFrom .

scinex:motivates a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "motivates" ;
    rdfs:comment "Links a research objective to the research process it drives. A stated objective — such as improving translation quality or reducing model size — motivates the choice of methodology, the design of experiments, or the selection of data processing steps. Declared asymmetric and irreflexive to enforce directionality. The inverse property scinex:achieves enables bidirectional objective–process reasoning without additional triple authoring." ;
    rdfs:domain scinex:ResearchObjective ;
    rdfs:range scinex:ResearchProcess .

scinex:reports a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "reports" ;
    rdfs:comment "Associates an academic paper with the research processes it describes, including its methodology, data processing pipeline, and experiments. The property-chain axiom (reports∘comprises) propagates reporting transitively down the process hierarchy: if a paper reports a methodology and the methodology comprises an experiment, the reasoner infers that the paper also reports that experiment. Declared asymmetric and irreflexive to enforce directionality." ;
    rdfs:domain scinex:AcademicPaper ;
    rdfs:range scinex:ResearchProcess ;
    owl:propertyChainAxiom ( scinex:reports scinex:comprises ) .

scinex:uses a owl:ObjectProperty ;
    rdfs:label "uses" ;
    rdfs:comment "Relates a research process to a research artifact it consumes as input. The property-chain axiom (comprises∘uses) propagates artifact usage up the process tree: if a methodology comprises an experiment and the experiment uses a dataset, the reasoner infers that the methodology also uses that dataset. This enables resource-level provenance queries at any granularity of the process hierarchy without requiring redundant triple authoring." ;
    rdfs:domain scinex:ResearchProcess ;
    rdfs:range scinex:ResearchArtifact ;
    owl:propertyChainAxiom ( scinex:comprises scinex:uses ) ;
    skos:altLabel "may_use",
        "takes_as_input",
        "used_as_input_to",
        "used_to_encode" .

scinex:writtenBy a owl:ObjectProperty ;
    rdfs:label "writtenBy" ;
    rdfs:comment "Links an academic paper to an author who contributed to it. This is the inverse of scinex:writes: the reasoner automatically derives writtenBy triples from every scinex:writes assertion. Enables paper-centric authorship queries such as 'who wrote Paper P?' without requiring explicit triple authoring in every A-Box." ;
    rdfs:domain scinex:AcademicPaper ;
    rdfs:range scinex:Author .

