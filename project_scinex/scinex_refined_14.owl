    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/S16-1018> ;
    scinex:hasSourceSentence "From the training set 10% of examples were ex- tracted to form a validation set." ;
    scinex:splitFrom <https://w3id.org/scinex/resource/S16-1018/training_set> .

scinex:Author a owl:Class ;
    rdfs:label "Author" ;
    rdfs:comment "A person who has made a substantive intellectual contribution to the conception, design, execution, analysis, or writing of an academic paper, as reflected in the paper's listed authorship." ;
    rdfs:subClassOf scinex:Person .

scinex:Experiment a owl:Class ;
    rdfs:label "Experiment" ;
    rdfs:comment "A structured empirical procedure conducted to test a hypothesis, evaluate a model, or measure the effect of specific variables under defined conditions. An experiment is described within a paper but is a distinct, independently representable entity. It takes datasets and models as inputs and produces experimental results as outputs." ;
    rdfs:subClassOf scinex:ResearchProcess .

scinex:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:comment "An individual human being involved in scientific research activities, extending foaf:Person with research-specific roles." ;
    rdfs:subClassOf foaf:Person,
        scinex:Agent .

scinex:Place a owl:Class ;
    rdfs:label "Place" ;
    rdfs:comment "A geographic or geopolitical location relevant to the research ecosystem. Representing places as a named class rather than literal strings enables LOD alignment with authoritative geographic knowledge bases such as DBpedia, Wikidata, and GeoNames, supporting geographic analysis of research output and institutional distribution." .

scinex:ResearchObjective a owl:Class ;
    rdfs:label "Research Objective" ;
    rdfs:comment "A clearly stated goal that an academic paper aims to achieve, such as proposing a novel algorithm, surpassing a benchmark, or validating a hypothesis. An objective frames the intent of a study and is a distinct conceptual entity — the same objective class can appear across multiple papers." ;
    rdfs:subClassOf scinex:ResearchContext .

scinex:produces a owl:AsymmetricProperty,
        owl:IrreflexiveProperty,
        owl:ObjectProperty ;
    rdfs:label "produces" ;
    rdfs:comment "Relates a research process to the research artifact it generates as output. Declared asymmetric and irreflexive to enforce output directionality. The property-chain axiom (comprises∘produces) propagates result attribution up the process tree: if a methodology comprises an experiment and the experiment produces a result, the reasoner infers that the methodology also produces that result. The inverse property scinex:producedBy enables artifact-to-process backward traversal." ;
    rdfs:domain scinex:ResearchProcess ;
    rdfs:range scinex:ResearchArtifact ;
    owl:propertyChainAxiom ( scinex:comprises scinex:produces ) .

<https://w3id.org/scinex/resource/2020.conll-1.24/cas> a owl:NamedIndividual,
        scinex:Model ;
    rdfs:label "cas" ;
    skos:definition "CAS is a model that stands for Copy Argument Sum." ;
    scinex:comparesAgainst <https://w3id.org/scinex/resource/2020.conll-1.24/cata> ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/2020.conll-1.24> ;
    scinex:hasSourceSentence "We then mix in the object/subject vectors and obtain three different models: CA for Copy Argument, CAS for Copy Argument Sum and CATA for Categorical Argument; see Table 4." .

<https://w3id.org/scinex/resource/BERT/english_wikipedia> a owl:NamedIndividual,
        scinex:Dataset ;
    rdfs:label "english wikipedia" ;
    skos:definition "English Wikipedia is a pre-training corpus consisting of 2,500 million words." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/BERT> ;
    scinex:hasSourceSentence "For the pre-training corpus we use the BooksCorpus (800M words) and English Wikipedia (2,500M words)." .

<https://w3id.org/scinex/resource/C12-3042/morfessor> a owl:NamedIndividual,
        scinex:Model ;
    rdfs:label "morfessor" ;
    skos:definition "Morfessor is a model whose results are significantly outperformed by a bilingual model using tokenized English." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/C12-3042> ;
    scinex:hasSourceSentence "The bilingual model using tokenized English significantly outperforms Morfessor result." .

<https://w3id.org/scinex/resource/C12-3042/morphology_analysis> a owl:NamedIndividual,
        scinex:ResearchTask ;
    rdfs:label "morphology analysis" ;
    skos:definition "Morphology analysis is the process of automatically deriving the morphological structure of a text through its English translation using a nonparametric model and blocked Gibbs sampling inference." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/C12-3042> ;
    scinex:hasSourceSentence "This paper presents a nonparametric model and blocked Gibbs sampling inference to automatically derive morphology analysis of a text through its English translation." .

<https://w3id.org/scinex/resource/C12-3042/multilingual_word_segmentation_task> a owl:NamedIndividual,
        scinex:ResearchTask ;
    rdfs:label "multilingual word segmentation task" ;
    skos:definition "The multilingual word segmentation task is a research problem addressed by applying a Bayesian model with Dirichlet process priors." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/C12-3042> ;
    scinex:hasSourceSentence "2 also applied a Bayesian model with Dirichlet Process priors to multilingual word segmentation task." .

<https://w3id.org/scinex/resource/C16-1036/predicting_most_adequate_speaking_style> a owl:NamedIndividual,
        scinex:ResearchTask ;
    rdfs:label "predicting most adequate speaking style" ;
    skos:definition "Predicting most adequate speaking style is a research task for which no specific evidence sentence is provided in the context." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/C16-1036> .

<https://w3id.org/scinex/resource/D12-1048/ollie> a owl:NamedIndividual,
        scinex:Model ;
    rdfs:label "ollie" ;
    skos:definition "OLLIE is a system that demonstrates higher performance than WOEparse, primarily due to its higher yield at comparable precision." ;
    scinex:comparesAgainst <https://w3id.org/scinex/resource/D12-1048/reverb>,
        <https://w3id.org/scinex/resource/D12-1048/woeparse> ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/D12-1048> ;
    scinex:hasSourceSentence "In our experiments (see Figure 5) we find WOEparse to have lower precision and yield than OLLIE." .

<https://w3id.org/scinex/resource/D12-1048/reverb> a owl:NamedIndividual,
        scinex:Model ;
    rdfs:label "reverb" ;
    skos:definition "REVERB is a system evaluated alongside OLLIE and WOEparse, contributing to a total of 1,945 extractions from the dataset." ;
    scinex:comparesAgainst <https://w3id.org/scinex/resource/D12-1048/woeparse> ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/D12-1048> ;
    scinex:hasSourceSentence "We ran three systems, OLLIE, REVERB and WOEparse on this dataset resulting in a total of 1,945 extractions from all three systems." .

<https://w3id.org/scinex/resource/D12-1051/conll_data> a owl:NamedIndividual,
        scinex:TrainingDataset ;
    rdfs:label "conll data" ;
    skos:definition "CoNLL data is a training dataset used to evaluate the state-of-the-art performance of latent dynamic conditional random fields on the NP-chunking task." ;
    scinex:extractedFrom <https://w3id.org/scinex/resource/paper/D12-1051> ;
    scinex:hasSourceSentence "(2008) used the latent-dynamic conditional random fields (LDCRF) to explicitly learn the hidden substructure of shallow phrases, achieving state-of-the-art performance over the NP-chunking task on the CoNLL data." .

<https://w3id.org/scinex/resource/D12-1051/ctb4> a owl:NamedIndividual,
